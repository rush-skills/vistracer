{
  "name": "vistracer",
  "version": "0.1.0",
  "description": "Electron-based visual traceroute application rendering hop paths on a 3D globe.",
  "private": true,
  "main": "dist/main/src/main/main.js",
  "author": "VisTracer Team",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -c \"blue,magenta,green\" \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput & tsc-alias -p tsconfig.main.json --watch",
    "dev:renderer": "vite --config vite.config.ts",
    "dev:electron": "wait-on dist/main/src/main/main.js && cross-env NODE_ENV=development electron .",
    "build": "npm run build:clean && npm run build:main && npm run build:renderer",
    "build:clean": "rimraf dist",
    "build:main": "tsc -p tsconfig.main.json && tsc-alias -p tsconfig.main.json",
    "build:renderer": "tsc -p tsconfig.renderer.json && vite build --config vite.config.ts",
    "start": "cross-env NODE_ENV=production electron .",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc -p tsconfig.renderer.json --noEmit && tsc -p tsconfig.main.json --noEmit"
  },
  "dependencies": {
    "@react-three/drei": "^9.101.3",
    "@react-three/fiber": "^8.15.17",
    "@reduxjs/toolkit": "^2.2.3",
    "@tanstack/react-query": "^5.29.0",
    "@visx/geo": "^3.7.0",
    "electron": "^38.4.0",
    "electron-log": "^5.1.3",
    "electron-store": "^9.0.0",
    "lz-string": "^1.5.0",
    "maxmind": "^4.3.16",
    "node-machine-id": "^1.1.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.1.0",
    "three": "^0.163.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.3",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/lodash": "^4.17.13",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.77",
    "@types/react-dom": "^18.2.25",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^24.1.3",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "tsc-alias": "^1.8.8",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5",
    "vite": "^7.1.12",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "wait-on": "^7.2.0"
  },
  "engines": {
    "node": ">=18.13.0"
  }
}
