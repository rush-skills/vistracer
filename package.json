{
  "name": "vistracer",
  "version": "0.2.0",
  "description": "Tauri-based visual traceroute application rendering hop paths on a 3D globe.",
  "private": true,
  "type": "module",
  "author": {
    "name": "VisTracer Team",
    "email": "vistracer@rush-skills.dev"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rush-skills/vistracer.git"
  },
  "bugs": {
    "url": "https://github.com/rush-skills/vistracer/issues"
  },
  "homepage": "https://vistracer.anks.in",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "dev:renderer": "vite --config vite.config.ts",
    "build": "npm run build:renderer",
    "build:renderer": "tsc -p tsconfig.renderer.json && vite build --config vite.config.ts",
    "tauri": "cargo tauri",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "cargo tauri build",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc -p tsconfig.renderer.json --noEmit"
  },
  "dependencies": {
    "@react-three/drei": "^9.101.3",
    "@react-three/fiber": "^8.15.17",
    "@tanstack/react-query": "^5.29.0",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-fs": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.1.0",
    "three": "^0.163.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.3",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.77",
    "@types/react-dom": "^18.2.25",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^24.1.3",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5",
    "vite": "^7.1.12",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
