-
-  const next = new Promise<void>((resolve) => {
-    release = resolve;
-  });
-
-  providerQueues.set(
-    provider,
-    previous
-      .catch(() => undefined)
-      .then(() => next)
-      .catch(() => undefined)
-  );
-
-  await previous.catch(() => undefined);
-
-  try {
-    // Enforce rate limiting before making the request
-    await enforceRateLimit(provider);
-    return await fn();
-  } finally {
-    release?.();
-  }
-}
